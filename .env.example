# Server
PORT=8080
HTTPS_REQUIRED=false
NODE_ENV=development
LOG_LEVEL=info

# FlightHub 2 (Shamal only — never share with external viewers)
FH2_MODE=mock
FH2_BASE_URL=https://es-flight-api-us.djigate.com
FH2_ORG_TOKEN=
FH2_PROJECT_UUID=
FH2_LANGUAGE=en

# Shamal Platform — admin login only (viewers are created in Admin Settings UI)
admin_id=admin
admin_password=change-me-strong-password

# Optional Shamal operator account (staff UI)
# CC_OPERATOR_ID=operator
# CC_OPERATOR_PASSWORD=change-me

# External viewer REST API keys (optional; admin-created viewers get their own keys automatically)
VIEWER_API_KEYS=
VIEWER_API_KEY_ROLES=
VIEWER_IP_ALLOWLIST=
VIEWER_EVENT_CALLBACK_URL=
VIEWER_EVENT_CALLBACK_SECRET=
# Legacy fallback: MARAFIQ_API_KEYS, MARAFIQ_API_KEY_ROLES, etc.

WEBHOOK_SECRET=change-me-webhook-secret
# Public URL for viewer webhook links shown in the platform UI
# PUBLIC_API_BASE_URL=https://shamal.sa/api

MONGODB_URI=mongodb://localhost:27017/shamal_middleware
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
TELEMETRY_SSE_INTERVAL_MS=10000

# Do NOT use CC_USERS or CC_SESSION_SECRET — removed.
# Session signing uses data/.platform-session-secret (auto-created).
# Viewer accounts live in data/viewer-users.json (Admin Settings).
