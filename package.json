{
  "name": "shamal-fh2-middleware",
  "version": "1.0.0",
  "description": "Shamal FH2 External Viewer Middleware — restricted viewer access to Shamal FlightHub 2 data",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/ui && cp -r src/ui dist/ui && cp -r src/fixtures dist/fixtures",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:setup": "bash scripts/setup-db.sh",
    "seed:demo-event": "tsx scripts/seed-demo-event.ts",
    "demo": "bash scripts/demo.sh",
    "test:readonly": "tsx scripts/auto-test-readonly.ts",
    "test:viewer-routes": "tsx scripts/test-viewer-route-aliases.ts",
    "test:fh2-projects": "tsx scripts/test-fh2-project-management.ts",
    "test:rest-api-keys": "tsx scripts/test-rest-api-keys.ts",
    "test:rest-api-keys-phase4": "tsx scripts/test-rest-api-keys-phase4.ts",
    "test:service-accounts": "tsx scripts/test-service-accounts.ts",
    "test:readonly:monitor": "bash scripts/auto-test-monitor.sh 2 10",
    "test:readonly:report": "tsx scripts/generate-test-report.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "mongodb": "^6.17.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/uuid": "^10.0.0",
    "@vercel/node": "^5.8.22",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
