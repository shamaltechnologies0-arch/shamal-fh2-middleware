{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "installCommand": "npm install --include=dev && cd apps/web && npm install --include=dev",
  "framework": null,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "{data/**,openapi/**,dist/**,public/**,apps/api/src/assets/**}"
    }
  }
}
