{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/apps/api/src",
    "rootDir": "apps/api/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@api/*": ["./apps/api/src/*"],
      "@shared/*": ["./packages/shared/src/*"],
      "@types/*": ["./packages/types/src/*"]
    }
  },
  "include": ["apps/api/src/**/*"],
  "exclude": ["node_modules", "dist", "apps/web", "packages"]
}
